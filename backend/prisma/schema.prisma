model crm_configs {
  id                    Int      @id @default(autoincrement())
  business_id           BigInt
  phase                 String   // "FREE_SEMINAR" or "AFTER_SEMINAR"
  is_ai_active          Boolean  @default(false)
  is_auto_reply_active  Boolean  @default(false)
  batch_id              BigInt?
